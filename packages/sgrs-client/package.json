{
  "name": "@sgrs/sgrs-client",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "TypeScript client for the SGRS Governed Swarm control plane HTTP API (/v1). Use from your own agents against a swarm runtime on-prem or in the cloud.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "homepage": "https://github.com/DealExMachina/open-governed-swarm-of-agents/tree/main/packages/sgrs-client#readme",
  "bugs": {
    "url": "https://github.com/DealExMachina/open-governed-swarm-of-agents/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DealExMachina/open-governed-swarm-of-agents.git",
    "directory": "packages/sgrs-client"
  },
  "keywords": [
    "sgrs",
    "governed-swarm",
    "control-plane",
    "multi-agent"
  ],
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
