{
  "name": "swarm-of-governed-agents",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "swarm": "node --loader ts-node/esm src/swarm.ts",
    "swarm:start": "bash scripts/swarm-hatchery.sh",
    "swarm:stop": "bash scripts/swarm-stop.sh",
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "start": "node dist/swarm.js",
    "loadgen": "node dist/loadgen.js",
    "seed": "node --loader ts-node/esm scripts/seed-context.ts",
    "seed:all": "node --loader ts-node/esm scripts/seed-all.ts",
    "seed:hitl": "node --loader ts-node/esm scripts/seed-hitl-scenario.ts",
    "seed:exp1": "node --loader ts-node/esm scripts/seed-exp1.ts",
    "seed:exp2": "node --loader ts-node/esm scripts/seed-exp2-graph.ts",
    "seed:exp3": "npx tsx scripts/seed-exp3-adversarial.ts",
    "simulate:mitl": "node --loader ts-node/esm scripts/simulate-mitl-approve.ts",
    "exp:collect": "node --loader ts-node/esm scripts/collect-experiment-results.ts",
    "exp:drive": "node --loader ts-node/esm scripts/drive-experiment.ts",
    "seed:loadgen": "node --loader ts-node/esm scripts/loadgen-inject.ts",
    "exp:load": "bash scripts/run-load-experiment.sh",
    "seed:demo": "node --loader ts-node/esm scripts/seed-demo.ts",
    "demo": "node --loader ts-node/esm demo/demo-server.ts",
    "demo:preflight": "bash scripts/demo-preflight.sh",
    "seed:governance-e2e": "node --loader ts-node/esm scripts/seed-governance-e2e.ts",
    "verify:governance-paths": "node --loader ts-node/esm scripts/verify-governance-paths.ts",
    "check:model": "node --loader ts-node/esm scripts/check-model-reachable.ts",
    "check:benchmark-manifests": "pnpm exec tsx scripts/check-benchmark-manifests.ts",
    "benchmark:smoke-llm": "pnpm exec tsx scripts/benchmark-comparative.ts --preset=smoke-llm",
    "benchmark:smoke-llm:all": "pnpm exec tsx scripts/benchmark-smoke-llm-scenarios.ts",
    "check:services": "node --loader ts-node/esm scripts/check-services.ts",
    "test:postgres-ollama": "node --loader ts-node/esm scripts/test-postgres-ollama.ts",
    "observe": "node --loader ts-node/esm scripts/observer.ts",
    "observability": "docker compose up -d otel-collector prometheus grafana",
    "feed": "node --loader ts-node/esm src/feed.ts",
    "ensure-bucket": "node --loader ts-node/esm scripts/ensure-bucket.ts",
    "ensure-schema": "node --loader ts-node/esm scripts/ensure-schema.ts",
    "ensure-stream": "node --loader ts-node/esm scripts/ensure-stream.ts",
    "ensure-pull-consumers": "node --loader ts-node/esm scripts/ensure-pull-consumers.ts",
    "reset-e2e": "node --loader ts-node/esm scripts/reset-e2e.ts",
    "reset-telemetry": "bash scripts/reset-telemetry.sh",
    "reset-all": "RESET_TELEMETRY=1 node --loader ts-node/esm scripts/reset-e2e.ts",
    "db-size": "node --loader ts-node/esm scripts/db-size.ts",
    "bootstrap-once": "node --loader ts-node/esm scripts/bootstrap-once.ts",
    "build:rust": "cd sgrs-core && npx napi build --release --platform",
    "build:rust:debug": "cd sgrs-core && npx napi build --platform",
    "benchmark:sgrs": "npx tsx scripts/benchmark-sgrs-load.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test --max-warnings 50",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "demo:open": "bash scripts/open-demo.sh",
    "exp:e19": "pnpm dlx tsx scripts/exp-e19-extract-loss.ts",
    "exp:e20": "pnpm dlx tsx scripts/exp-e20-escalation-necessity.ts",
    "exp:model-evals": "npx tsx scripts/model-qualification-hypersphere.ts",
    "p0:refresh-onboarding-policy": "npx tsx scripts/p0-refresh-onboarding-policy.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.22",
    "@aws-sdk/client-s3": "^3.993.0",
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.1",
    "@mastra/core": "^0.24.9",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@symbolica/agentica": "^0.4.1",
    "dotenv": "^16.4.5",
    "jose": "^6.1.3",
    "nats": "^2.29.3",
    "pg": "^8.13.0",
    "sgrs-core": "file:sgrs-core",
    "simple-statistics": "^7.8.8",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "exceljs": "^4.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "hono": ">=4.12.4",
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.0",
      "path-to-regexp": ">=0.1.13",
      "picomatch": ">=4.0.4"
    }
  }
}